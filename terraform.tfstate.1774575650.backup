            "private_ip": "10.253.125.114",
            "public_dns": "ec2-54-214-106-227.compute-1.amazonaws.com",
            "public_ip": "54.214.106.227",
            "region": "us-east-1",
            "root_block_device": [
              {
                "delete_on_termination": true,
                "device_name": "/dev/sda1",
                "encrypted": false,
                "iops": 0,
                "kms_key_id": "",
